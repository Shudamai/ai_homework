import torch
import torch.nn as nn
import torch.optim as optim
import torchvision
import torchvision.transforms as transforms
import matplotlib.pyplot as plt
import numpy as np
from torch.utils.data import DataLoader
import matplotlib as mpl

# 设置中文字体支持
import platform
system = platform.system()
if system == 'Windows':
    plt.rcParams['font.sans-serif'] = ['SimHei']  # 用来正常显示中文标签
    plt.rcParams['axes.unicode_minus'] = False  # 用来正常显示负号
elif system == 'Linux':
    plt.rcParams['font.sans-serif'] = ['WenQuanYi Micro Hei']  # Linux常用中文字体
    plt.rcParams['axes.unicode_minus'] = False
elif system == 'Darwin':  # macOS
    plt.rcParams['font.sans-serif'] = ['Heiti TC', 'Arial Unicode MS']  # macOS常用中文字体
    plt.rcParams['axes.unicode_minus'] = False
    
# 全局设置中文显示
mpl.rcParams['font.family'] = plt.rcParams['font.sans-serif'][0]
# 设置随机种子以确保结果可复现
torch.manual_seed(42)
# 设置设备，优先使用GPU
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
print(f"使用设备: {device}")
# 定义数据预处理：将图像转换为张量并归一化
transform = transforms.Compose([
    transforms.ToTensor(),  # 将PIL图像转换为张量，同时将像素值缩放到[0,1]
    transforms.Normalize((0.1307,), (0.3081,))  # 使用MNIST数据集的均值和标准差进行归一化
])
# 加载MNIST训练集和测试集
train_dataset = torchvision.datasets.MNIST(
    root='./data',  # 数据存储路径
    train=True,     # 指定为训练集
    download=True,  # 如果数据不存在，则下载
    transform=transform  # 应用上面定义的转换
)
test_dataset = torchvision.datasets.MNIST(
    root='./data',
    train=False,
    download=True,
    transform=transform
)
# 创建数据加载器，用于批量加载数据
batch_size = 64
train_loader = DataLoader(
    dataset=train_dataset,
    batch_size=batch_size,
    shuffle=True  # 打乱数据，提高训练效果
)
test_loader = DataLoader(
    dataset=test_dataset,
    batch_size=batch_size,
    shuffle=False  # 测试集不需要打乱
)
# 定义三层全连接神经网络
class ThreeLayerNN(nn.Module):
    def __init__(self):
        super(ThreeLayerNN, self).__init__()
        # 第一层：输入层到隐藏层1 (784 -> 128)
        self.fc1 = nn.Linear(28 * 28, 128)  # MNIST图像大小为28x28=784
        # 第二层：隐藏层1到隐藏层2 (128 -> 64)
        self.fc2 = nn.Linear(128, 64)
        # 第三层：隐藏层2到输出层 (64 -> 10)，10个类别对应数字0-9
        self.fc3 = nn.Linear(64, 10)
        # ReLU激活函数
        self.relu = nn.ReLU()
    
    def forward(self, x):
        # 将输入张量展平为向量
        x = x.view(-1, 28 * 28)
        # 第一层线性变换后应用ReLU激活函数
        x = self.relu(self.fc1(x))
        # 第二层线性变换后应用ReLU激活函数
        x = self.relu(self.fc2(x))
        # 第三层线性变换（不使用激活函数，因为后面会用交叉熵损失）
        x = self.fc3(x)
        return x
# 定义改进的网络：五层神经网络，使用不同激活函数
class ImprovedNN(nn.Module):
    def __init__(self, activation_fn=nn.ReLU()):
        super(ImprovedNN, self).__init__()
        self.fc1 = nn.Linear(28 * 28, 256)
        self.fc2 = nn.Linear(256, 128)
        self.fc3 = nn.Linear(128, 64)
        self.fc4 = nn.Linear(64, 32)
        self.fc5 = nn.Linear(32, 10)
        # 可配置的激活函数
        self.activation = activation_fn
        # Dropout用于防止过拟合
        self.dropout = nn.Dropout(0.2)
    
    def forward(self, x):
        x = x.view(-1, 28 * 28)
        x = self.activation(self.fc1(x))
        x = self.dropout(x)
        x = self.activation(self.fc2(x))
        x = self.dropout(x)
        x = self.activation(self.fc3(x))
        x = self.activation(self.fc4(x))
        x = self.fc5(x)
        return x
# 训练函数
def train_model(model, train_loader, criterion, optimizer, num_epochs):
    model.to(device)  # 将模型移动到指定设备
    train_losses = []  # 记录每个epoch的训练损失
    
    for epoch in range(num_epochs):
        running_loss = 0.0
        for i, (images, labels) in enumerate(train_loader):
            # 将数据转移到指定设备
            images, labels = images.to(device), labels.to(device)
            
            # 前向传播
            outputs = model(images)
            loss = criterion(outputs, labels)
            
            # 反向传播和优化
            optimizer.zero_grad()  # 清除现有梯度
            loss.backward()        # 反向传播计算梯度
            optimizer.step()       # 更新参数
            
            running_loss += loss.item()
            
        # 计算并记录每个epoch的平均损失
        epoch_loss = running_loss / len(train_loader)
        train_losses.append(epoch_loss)
        
        print(f'Epoch [{epoch+1}/{num_epochs}], Loss: {epoch_loss:.4f}')
    
    return train_losses
# 测试函数
def test_model(model, test_loader):
    model.eval()  # 设置为评估模式
    model.to(device)
    
    with torch.no_grad():  # 不计算梯度
        correct = 0
        total = 0
        for images, labels in test_loader:
            images, labels = images.to(device), labels.to(device)
            outputs = model(images)
            _, predicted = torch.max(outputs.data, 1)  # 获取最高概率的类别索引
            total += labels.size(0)
            correct += (predicted == labels).sum().item()
    
    accuracy = 100 * correct / total
    print(f'测试准确率: {accuracy:.2f}%')
    return accuracy
# 对比不同激活函数和网络结构
def compare_activations_and_models():
    # 准备不同的激活函数
    activation_functions = {
        'ReLU': nn.ReLU(),
        'LeakyReLU': nn.LeakyReLU(),
        'SELU': nn.SELU(),
        'Tanh': nn.Tanh(),
        'Sigmoid': nn.Sigmoid()
    }
    
    results = {}
    
    # 测试基本的三层网络
    model_basic = ThreeLayerNN()
    criterion = nn.CrossEntropyLoss()
    optimizer = optim.Adam(model_basic.parameters(), lr=0.001)
    
    print("\n训练基本三层网络...")
    train_losses = train_model(model_basic, train_loader, criterion, optimizer, num_epochs=5)
    acc_basic = test_model(model_basic, test_loader)
    results['基础三层网络'] = {'accuracy': acc_basic, 'losses': train_losses}
    
    # 测试不同激活函数的改进网络
    for name, activation in activation_functions.items():
        print(f"\n训练使用 {name} 的改进网络...")
        model = ImprovedNN(activation_fn=activation)
        optimizer = optim.Adam(model.parameters(), lr=0.001)
        
        train_losses = train_model(model, train_loader, criterion, optimizer, num_epochs=5)
        accuracy = test_model(model, test_loader)
        results[f'改进网络-{name}'] = {'accuracy': accuracy, 'losses': train_losses}
    
    return results
# 不同训练轮数的实验
def experiment_with_epochs():
    epochs_list = [1, 5, 10, 15, 20]
    results = {}
    
    for epochs in epochs_list:
        print(f"\n使用 {epochs} 个epochs进行训练...")
        model = ImprovedNN()  # 使用改进的网络
        criterion = nn.CrossEntropyLoss()
        optimizer = optim.Adam(model.parameters(), lr=0.001)
        
        train_losses = train_model(model, train_loader, criterion, optimizer, num_epochs=epochs)
        accuracy = test_model(model, test_loader)
        results[epochs] = {'accuracy': accuracy, 'losses': train_losses}
    
    return results
# 可视化训练损失
def plot_losses(results, title="训练损失对比"):
    plt.figure(figsize=(12, 6))
    
    for name, data in results.items():
        if 'losses' in data:
            plt.plot(range(1, len(data['losses'])+1), data['losses'], label=f"{name}")
    
    plt.title(title, fontsize=14)
    plt.xlabel('Epoch', fontsize=12)
    plt.ylabel('Loss', fontsize=12)
    plt.legend(loc='best', fontsize=10)
    plt.grid(True)
    plt.tight_layout()
    plt.savefig('训练损失对比.png', dpi=300, bbox_inches='tight')
    plt.show()
# 可视化准确率对比
def plot_accuracies(results, title="测试准确率对比"):
    names = list(results.keys())
    accuracies = [data['accuracy'] for data in results.values()]
    
    plt.figure(figsize=(12, 6))
    bars = plt.bar(range(len(names)), accuracies, color='skyblue')
    
    # 在柱状图顶部添加具体数值
    for bar, acc in zip(bars, accuracies):
        height = bar.get_height()
        plt.text(bar.get_x() + bar.get_width()/2., height + 0.5,
                f'{acc:.2f}%', ha='center', va='bottom', fontsize=9)
    
    plt.title(title, fontsize=14)
    plt.xlabel('模型', fontsize=12)
    plt.ylabel('准确率 (%)', fontsize=12)
    plt.xticks(range(len(names)), names, rotation=45, ha='right', fontsize=9)
    plt.tight_layout()
    plt.grid(axis='y')
    plt.savefig('测试准确率对比.png', dpi=300, bbox_inches='tight')
    plt.show()
# 可视化epochs实验结果
def plot_epoch_experiment(results):
    epochs = list(results.keys())
    accuracies = [data['accuracy'] for data in results.values()]
    
    plt.figure(figsize=(10, 5))
    plt.plot(epochs, accuracies, marker='o', linestyle='-', color='blue')
    
    # 添加数据标签
    for x, y in zip(epochs, accuracies):
        plt.text(x, y + 0.3, f'{y:.2f}%', ha='center')
    
    plt.title('不同训练轮数的准确率对比', fontsize=14)
    plt.xlabel('Epochs', fontsize=12)
    plt.ylabel('准确率 (%)', fontsize=12)
    plt.grid(True)
    plt.tight_layout()
    plt.savefig('不同训练轮数的准确率对比.png', dpi=300, bbox_inches='tight')
    plt.show()
    
    # 绘制所有轮数的损失曲线
    plt.figure(figsize=(12, 6))
    for epoch, data in results.items():
        plt.plot(range(1, len(data['losses'])+1), data['losses'], label=f"Epochs={epoch}")
    
    plt.title('不同训练轮数的损失曲线', fontsize=14)
    plt.xlabel('Epoch', fontsize=12)
    plt.ylabel('Loss', fontsize=12)
    plt.legend(loc='best', fontsize=10)
    plt.grid(True)
    plt.tight_layout()
    plt.savefig('不同训练轮数的损失曲线.png', dpi=300, bbox_inches='tight')
    plt.show()
# 显示一些样本图像
def show_samples():
    # 获取一批数据
    examples = iter(test_loader)
    example_data, example_targets = next(examples)
    example_data = example_data[:10]  # 只展示前10个样本
    
    plt.figure(figsize=(12, 6))
    for i in range(10):
        plt.subplot(2, 5, i+1)
        plt.imshow(example_data[i][0], cmap='gray')
        plt.title(f'标签: {example_targets[i]}', fontsize=11)
        plt.axis('off')
    plt.suptitle('MNIST手写数字样本', fontsize=14)
    plt.tight_layout()
    plt.savefig('MNIST样本图像.png', dpi=300, bbox_inches='tight')
    plt.show()
# 主函数
def main():
    # 显示样本
    show_samples()
    
    # 比较不同激活函数和网络结构
    print("\n比较不同激活函数和网络结构...")
    activation_results = compare_activations_and_models()
    plot_losses(activation_results, "不同激活函数的训练损失对比")
    plot_accuracies(activation_results, "不同激活函数的测试准确率对比")
    
    # 实验不同训练轮数
    print("\n实验不同训练轮数...")
    epoch_results = experiment_with_epochs()
    plot_epoch_experiment(epoch_results)
    
    print("\n所有实验完成！")
if __name__ == "__main__":
    main()
